{
  "manifest_version": 3,
  "name": "Reflexión Digital",
  "version": "1.0",
  "description": "Muy pronto sabrás qué hace",
  
  "permissions": [
    "activeTab"
  ],

  "content_scripts": [
    {
      "matches": [
        "*://*.google.com/*",
        "*://*.facebook.com/*",
        "*://*.amazon.com.mx/*",
        "*://*.pullandbear.com/mx/hombre-n6228/*"
      ],
      "js": ["popup.js"]
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "imagen.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}